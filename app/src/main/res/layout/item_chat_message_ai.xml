<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Avatar IA: círculo amarillo con emoji 🤖 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="@color/neo_yellow"
        app:strokeColor="@color/neo_black"
        app:strokeWidth="1.5dp"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🤖"
            android:textSize="16sp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Burbuja del mensaje IA -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="@color/app_surface"
        app:strokeColor="@color/app_stroke"
        app:strokeWidth="1dp"
        app:cardElevation="1dp">

        <TextView
            android:id="@+id/tvAiMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textColor="@color/neo_black"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            android:fontFamily="sans-serif" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
