<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_profile.xml -->
<!-- DESCRIPCIÓN: Pantalla de perfil de usuario con estadísticas personalizadas y listado de opciones de configuración en formato Neo-Brutalist. -->

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neo_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER DE PERFIL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <!-- Imagen de Perfil Circular -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivUserProfileImage"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@color/white"
                android:padding="12dp"
                app:shapeAppearanceOverlay="@style/CircleAppearance"
                app:strokeColor="@color/neo_black"
                app:strokeWidth="3dp"
                android:contentDescription="Foto de perfil del usuario"
                android:layout_marginBottom="16dp" />

            <!-- Nombre de Usuario -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Borja Martín"
                android:textColor="@color/neo_black"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Email de Usuario -->
            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="borja@travelplanner.ai"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- SECCIÓN DE ESTADÍSTICAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mis Estadísticas"
            android:textColor="@color/neo_black"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Fila de Estadísticas side-by-side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="28dp">

            <!-- Card 1: Viajes -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_stats_card_pink"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="@color/neo_black"
                        android:contentDescription="Icono de viajes" />

                    <TextView
                        android:id="@+id/tvStatsTripsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8"
                        android:textColor="@color/neo_black"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Viajes"
                        android:textColor="@color/neo_black"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </FrameLayout>

            <!-- Card 2: Lugares -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/bg_stats_card_yellow"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/neo_black"
                        android:contentDescription="Icono de lugares" />

                    <TextView
                        android:id="@+id/tvStatsPlacesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14"
                        android:textColor="@color/neo_black"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lugares"
                        android:textColor="@color/neo_black"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </FrameLayout>

            <!-- Card 3: Presupuesto -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_stats_card_green"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="@color/neo_black"
                        android:contentDescription="Icono de presupuesto" />

                    <TextView
                        android:id="@+id/tvStatsBudgetSpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.2K €"
                        android:textColor="@color/neo_black"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ahorrado"
                        android:textColor="@color/neo_black"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- SECCIÓN DE CONFIGURACIÓN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opciones de Configuración"
            android:textColor="@color/neo_black"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Card Clickable: Editar Perfil -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEditProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/primary_blue"
                    android:contentDescription="Icono editar" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Editar Perfil"
                    android:textColor="@color/neo_black"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/text_muted"
                    android:contentDescription="Ir" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card Clickable: Notificaciones -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="@color/primary_purple"
                    android:contentDescription="Icono notificaciones" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Ajustes de Notificaciones"
                    android:textColor="@color/neo_black"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/text_muted"
                    android:contentDescription="Ir" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card Clickable: Ayuda y Soporte -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHelpSupport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_help"
                    app:tint="@color/neo_yellow"
                    android:contentDescription="Icono ayuda" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Ayuda y Soporte"
                    android:textColor="@color/neo_black"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/text_muted"
                    android:contentDescription="Ir" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card Clickable: Cerrar Sesión (Rojo Brutalista) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#EF4444"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="2.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/white"
                    android:contentDescription="Icono salir" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Cerrar Sesión"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>