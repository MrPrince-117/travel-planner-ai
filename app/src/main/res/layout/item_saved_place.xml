<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/app_surface"
    app:strokeColor="@color/neo_black"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Icono de lugar en círculo amarillo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/neo_yellow"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="2dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📍"
                android:textSize="20sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Nombre, dirección y categoría -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvSavedPlaceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Torre Eiffel"
                android:textColor="@color/neo_black"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvSavedPlaceAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Champ de Mars, París"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvSavedPlaceCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monumento"
                android:textColor="@color/neo_pink"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Botones: Maps y eliminar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenMaps"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Maps"
                android:textSize="11sp"
                android:textColor="@color/primary_blue"
                app:strokeColor="@color/primary_blue"
                app:strokeWidth="1.5dp"
                app:cornerRadius="10dp"
                android:paddingHorizontal="10dp" />

            <ImageButton
                android:id="@+id/btnDeletePlace"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:contentDescription="Eliminar lugar"
                app:tint="@color/text_muted" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
