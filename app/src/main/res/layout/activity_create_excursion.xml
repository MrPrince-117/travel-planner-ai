<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neo_bg"
    android:padding="16dp">

    <!-- Title / Header -->
    <TextView
        android:id="@+id/tvCreateExcursionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Añadir Excursión"
        android:textColor="@color/neo_black"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCreateExcursionSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Agrega actividades específicas para complementar tu viaje"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/tvCreateExcursionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Form Scroll Container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollExcursionForm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvCreateExcursionSubtitle"
        app:layout_constraintBottom_toTopOf="@id/btnSaveExcursion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Activity Name Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilExcursionName"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Nombre de la Actividad (Ej: Visita al Museo)"
                app:boxStrokeColor="@color/neo_black"
                app:hintTextColor="@color/text_dark"
                app:boxStrokeWidth="2dp"
                app:boxStrokeWidthFocused="3dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExcursionName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/neo_black"
                    android:inputType="textAutoCorrect|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Location/Place Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilExcursionLocation"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Lugar / Dirección (Ej: Louvre, París)"
                app:boxStrokeColor="@color/neo_black"
                app:hintTextColor="@color/text_dark"
                app:boxStrokeWidth="2dp"
                app:boxStrokeWidthFocused="3dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExcursionLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/neo_black"
                    android:inputType="textAutoCorrect|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Date and Time Row Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Excursion Date -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilExcursionDate"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Fecha"
                    app:boxStrokeColor="@color/neo_black"
                    app:hintTextColor="@color/text_dark"
                    app:boxStrokeWidth="2dp"
                    app:boxStrokeWidthFocused="3dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExcursionDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/neo_black"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none"
                        android:drawableEnd="@android:drawable/ic_menu_today"
                        android:drawableTint="@color/text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Excursion Time -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilExcursionTime"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Hora"
                    app:boxStrokeColor="@color/neo_black"
                    app:hintTextColor="@color/text_dark"
                    app:boxStrokeWidth="2dp"
                    app:boxStrokeWidthFocused="3dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExcursionTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/neo_black"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none"
                        android:drawableEnd="@android:drawable/ic_menu_recent_history"
                        android:drawableTint="@color/text_muted" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save Excursion Button -->
    <Button
        android:id="@+id/btnSaveExcursion"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginBottom="8dp"
        android:text="Guardar Excursión"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary"
        android:background="@drawable/neo_button_bg"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
