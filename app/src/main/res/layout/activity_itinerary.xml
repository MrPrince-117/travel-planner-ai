<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neo_bg">

    <!-- Custom Toolbar -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/neo_black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Mi Itinerario"
            android:textColor="@color/neo_black"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Days Selection TabLayout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabDays"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@color/neo_bg"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="@color/neo_pink"
        app:tabTextColor="@color/neo_black"
        app:tabIndicatorColor="@color/neo_pink"
        app:tabIndicatorHeight="4dp"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RecyclerView for Itinerary Items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItineraryItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tabDays"
        app:layout_constraintBottom_toTopOf="@id/btnGenerateAiItinerary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_place_result" />

    <!-- Prominent AI Itinerary Generator Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGenerateAiItinerary"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="Generar itinerario con IA"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        app:icon="@android:drawable/btn_star_big_on"
        app:iconTint="@color/white"
        app:iconGravity="textStart"
        app:backgroundTint="@color/neo_pink"
        app:strokeColor="@color/neo_black"
        app:strokeWidth="2dp"
        app:cornerRadius="16dp"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
