<?xml version="1.0" encoding="utf-8"?>
<!-- view_loading_state.xml -->
<!-- DESCRIPCIÓN: Vista de carga en pantalla completa y semi-transparente que bloquea interacciones de fondo mientras muestra el progreso. -->

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6FFF9E7"
    android:clickable="true"
    android:focusable="true"
    android:elevation="99dp">

    <!-- Contenedor del ProgressBar y el Texto -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ProgressBar con el color primario del proyecto (neo_pink) -->
        <ProgressBar
            android:id="@+id/pbLoading"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/neo_pink"
            android:indeterminate="true"
            android:layout_marginBottom="16dp" />

        <!-- Mensaje de Carga -->
        <TextView
            android:id="@+id/tvLoadingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando..."
            android:textColor="@color/neo_black"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>