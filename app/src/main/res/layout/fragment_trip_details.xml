<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_trip_details.xml -->
<!-- DESCRIPCIÓN: Detalle de viaje en formato Fragment (alternativa a Activity) con cabecera de imagen, descripción, acciones rápidas e itinerario/excursiones en estilo Neo-Brutalist. -->

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neo_bg">

    <!-- Scroll principal para el contenido -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollTripContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card de Imagen del Destino -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/neo_black"
                app:strokeWidth="3dp">

                <ImageView
                    android:id="@+id/ivTripDetailsImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:contentDescription="Imagen del destino" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Título del Destino -->
            <TextView
                android:id="@+id/tvTripDetailsName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="París, Francia 🇫🇷"
                android:textColor="@color/neo_black"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Fechas del Viaje -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_icon_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/primary_blue"
                    android:contentDescription="Icono fecha" />

                <TextView
                    android:id="@+id/tvTripDetailsDates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="15 Oct - 22 Oct, 2026"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Línea Separadora Neo-Brutalista -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2.5dp"
                android:background="@color/neo_black"
                android:layout_marginBottom="12dp" />

            <!-- Descripción del Viaje -->
            <TextView
                android:id="@+id/tvTripDetailsDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Un viaje romántico de eunsueño recorriendo los museos del Louvre, la Torre Eiffel y paseando por el Sena."
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="3sp"
                android:layout_marginBottom="24dp" />

            <!-- Acciones Rápidas (Itinerario & Consultar IA) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <!-- Botón: Ver Itinerario Completo -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewItinerary"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/neo_black"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/primary_blue"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="Icono itinerario" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ver Itinerario"
                            android:textColor="@color/neo_black"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Botón: Consultar IA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnConsultAI"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeColor="@color/neo_black"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/stat_notify_chat"
                            app:tint="@color/neo_yellow"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="Icono chat IA" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consultar IA"
                            android:textColor="@color/neo_black"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Sección de Excursiones -->
            <TextView
                android:id="@+id/tvExcursionsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tus Excursiones Planificadas"
                android:textColor="@color/neo_black"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- RecyclerView de Excursiones -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExcursions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_excursion_card"
                android:layout_marginBottom="72dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: Añadir Excursión (Conserva ID btnAddExcursion para compatibilidad) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddExcursion"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        app:tint="@color/neo_white"
        android:backgroundTint="@color/neo_pink"
        app:fabSize="normal"
        app:elevation="6dp"
        app:borderWidth="2dp"
        app:strokeColor="@color/neo_black"
        android:contentDescription="Añadir excursión"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>