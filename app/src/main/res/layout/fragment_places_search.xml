<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neo_bg"
    android:padding="16dp">

    <!-- Header Title -->
    <TextView
        android:id="@+id/tvSearchTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Explorar Lugares"
        android:textColor="@color/neo_black"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Search CardView -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSearch"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/white"
        app:strokeColor="@color/neo_black"
        app:strokeWidth="2dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSearchTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/neo_black" />

            <EditText
                android:id="@+id/etPlaceSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:hint="Buscar hoteles, restaurantes..."
                android:background="@null"
                android:textColor="@color/neo_black"
                android:textColorHint="@color/text_muted"
                android:textSize="16sp"
                android:inputType="text"
                android:imeOptions="actionSearch" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Chips Scroll View -->
    <HorizontalScrollView
        android:id="@+id/svChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/cardSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHotels"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoteles"
                android:textColor="@color/neo_black"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/neo_black"
                app:chipStrokeWidth="2dp"
                app:chipCornerRadius="12dp"
                android:fontFamily="sans-serif-bold"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRestaurants"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restaurantes"
                android:textColor="@color/neo_black"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/neo_black"
                app:chipStrokeWidth="2dp"
                app:chipCornerRadius="12dp"
                android:fontFamily="sans-serif-bold"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMuseums"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Museos"
                android:textColor="@color/neo_black"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/neo_black"
                app:chipStrokeWidth="2dp"
                app:chipCornerRadius="12dp"
                android:fontFamily="sans-serif-bold"
                android:textStyle="bold" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- RecyclerView Results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlaceResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/svChips"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_place_result" />

    <!-- Extended Floating Action Button -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabToggleMap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mapa"
        app:icon="@android:drawable/ic_dialog_map"
        android:textColor="@color/neo_black"
        app:iconTint="@color/neo_black"
        app:backgroundTint="@color/neo_yellow"
        app:strokeColor="@color/neo_black"
        app:strokeWidth="2dp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>