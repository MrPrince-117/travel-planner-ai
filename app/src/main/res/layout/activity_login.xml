<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neo_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="60dp" />

        <!-- Logo / Título -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Travel Planner"
            android:textColor="@color/neo_black"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Planifica tus viajes con IA"
            android:textColor="@color/neo_black"
            android:textSize="16sp"
            android:layout_marginBottom="48dp" />

        <!-- Email Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textColor="@color/neo_black"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Email EditText -->
        <EditText
            android:id="@+id/etLoginEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="tu@email.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/neo_edittext_bg"
            android:textColor="@color/neo_black"
            android:textColorHint="#9E9E9E"
            android:layout_marginBottom="24dp" />

        <!-- Password Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTRASEÑA"
            android:textColor="@color/neo_black"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Password EditText -->
        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:background="@drawable/neo_edittext_bg"
            android:textColor="@color/neo_black"
            android:textColorHint="#9E9E9E"
            android:layout_marginBottom="32dp" />

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="INICIAR SESIÓN"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/neo_pink"
            android:background="@drawable/neo_button_bg"
            android:stateListAnimator="@null"
            android:layout_marginBottom="24dp" />

        <!-- Register Link -->
        <TextView
            android:id="@+id/tvGoToRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="¿No tienes cuenta? Regístrate aquí"
            android:textColor="@color/neo_pink"
            android:textStyle="bold"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
