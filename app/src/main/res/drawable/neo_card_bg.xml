<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="6dp" android:left="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neo_black" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:bottom="6dp" android:right="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neo_white" />
            <stroke android:width="3dp" android:color="@color/neo_black" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>