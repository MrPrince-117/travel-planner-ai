<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow (Black block offset to the bottom) -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neo_black" />
        </shape>
    </item>
    <!-- Foreground (White card with thick black border) -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neo_white" />
            <stroke android:width="3dp" android:color="@color/neo_black" />
        </shape>
    </item>
</layer-list>
