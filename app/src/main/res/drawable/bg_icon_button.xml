<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo limpio para botones de icono sobre fondos claros (ej. botón volver).
     Círculo de superficie con borde sutil, sin sombras con offset. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#22000000">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/app_surface" />
            <stroke android:width="1.5dp" android:color="@color/app_stroke" />
        </shape>
    </item>
</ripple>
