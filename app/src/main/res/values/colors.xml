<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ════════════════════════════════════════════════════════════════
         COLORES FIJOS (idénticos en claro y oscuro)
         Se usan para texto/iconos sobre botones de color y para acentos.
         ════════════════════════════════════════════════════════════════ -->
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Tinta oscura fija: texto oscuro que SIEMPRE va sobre fondos de
         color claro (chips rosa/amarillo/verde, avatar, etc.). No cambia. -->
    <color name="ink_fixed">#1A1D24</color>

    <!-- Acentos de marca (fijos en ambos temas) -->
    <color name="neo_pink">#FF3399</color>
    <color name="neo_yellow">#FFD600</color>
    <color name="primary_blue">#3B82F6</color>
    <color name="primary_green">#10B981</color>
    <color name="primary_purple">#A855F7</color>
    <color name="danger_red">#E53935</color>
    <color name="danger_red_dark">#B71C1C</color>

    <!-- ════════════════════════════════════════════════════════════════
         COLORES SEMÁNTICOS — valores para el TEMA CLARO
         (la variante oscura está en values-night/colors.xml)
         Paleta basada en la imagen de referencia: fondo gris muy claro,
         tarjetas blancas, texto gris oscuro, acentos azul/verde/morado.
         ════════════════════════════════════════════════════════════════ -->

    <!-- Fondos -->
    <color name="neo_bg">#F4F5F7</color>          <!-- fondo de pantalla -->
    <color name="app_surface">#FFFFFF</color>     <!-- tarjetas / superficies -->
    <color name="app_surface_variant">#EEF1F5</color> <!-- barra búsqueda, burbujas, chips -->
    <color name="card_bg">#FFFFFF</color>
    <color name="bg_light">#F4F5F7</color>

    <!-- Tinta principal: texto, iconos y bordes "neo" -->
    <color name="neo_black">#1A1D24</color>
    <color name="neo_white">#FFFFFF</color>       <!-- relleno de superficies neo -->

    <!-- Texto -->
    <color name="text_dark">#1A1D24</color>       <!-- texto principal -->
    <color name="text_muted">#6B7280</color>      <!-- texto secundario / atenuado -->

    <!-- Bordes y separadores -->
    <color name="app_stroke">#E2E5EA</color>
    <color name="app_divider">#E6E8EC</color>

    <!-- Fondos pastel para iconos -->
    <color name="icon_bg_blue">#EFF6FF</color>
    <color name="icon_bg_green">#ECFDF5</color>
    <color name="icon_bg_purple">#FAF5FF</color>

    <!-- ════════════════════════════════════════════════════════════════
         Alias de compatibilidad
         ════════════════════════════════════════════════════════════════ -->
    <color name="primary">@color/neo_pink</color>
    <color name="secondary">@color/neo_yellow</color>
</resources>
